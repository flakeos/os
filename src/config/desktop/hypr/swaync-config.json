{
  "positionX": "right",
  "positionY": "top",
  "control-center-positionX": "right",
  "control-center-positionY": "top",
  "control-center-width": 380,
  "control-center-height": 720,
  "notification-window-width": 380,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "hide-empty-control-center": true,
  "layer": "overlay",
  "cssPriority": "user",
  "notification-icon-size": 32,
  "timeout": 10,
  "timeout-critical": 0,
  "widgets": [
    "title",
    "dnd",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 48,
      "image-radius": 6
    }
  }
}
